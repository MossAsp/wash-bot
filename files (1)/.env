# ============================================================
# .env — ตั้งค่า credentials ทั้งหมด
# วิธีใช้: คัดลอกไฟล์นี้แล้วบันทึกเป็น  .env
# ============================================================

# ── LINE Developers (https://developers.line.biz) ───────────
LINE_CHANNEL_SECRET=ใส่_Channel_Secret_ที่นี่
LINE_CHANNEL_ACCESS_TOKEN=ใส่_Channel_Access_Token_ที่นี่
ADMIN_LINE_USER_ID=ใส่_LINE_User_ID_ของ_Admin_ที่นี่

# ── Anthropic Claude (https://console.anthropic.com) ────────
ANTHROPIC_API_KEY=ใส่_API_Key_ที่นี่
